// Coinductive streams: PhiCF self-loop, Sqrt2CF -> Sqrt2Periodic self-loop
digraph coinductive_stream {
  bgcolor="transparent";
  node [
    fontname="Menlo"
    fontsize=11
    shape=box
    style="rounded,filled"
    fillcolor="#f5f5f4"
    color="#d6d3d1"
    penwidth=1.5
  ];
  edge [
    fontname="Menlo"
    fontsize=10
    penwidth=1.5
    arrowsize=0.8
  ];

  subgraph cluster_phi {
    label="Golden Ratio [1; 1, 1, 1, ...]";
    labeljust=l;
    fontname="Helvetica Neue";
    fontsize=11;
    style="rounded,dashed";
    color="#c084fc";
    bgcolor="#faf5ff";

    phi [label="PhiCF\nHead = N1" fillcolor="#f3e8ff" color="#c084fc"];
    phi -> phi [label="Tail = Self" color="#9333ea" fontcolor="#9333ea"];
  }

  subgraph cluster_sqrt2 {
    label="sqrt(2) = [1; 2, 2, 2, ...]";
    labeljust=l;
    fontname="Helvetica Neue";
    fontsize=11;
    style="rounded,dashed";
    color="#86efac";
    bgcolor="#f0fdf4";

    sqrt2 [label="Sqrt2CF\nHead = N1" fillcolor="#dcfce7" color="#86efac"];
    periodic [label="Sqrt2Periodic\nHead = N2" fillcolor="#bbf7d0" color="#16a34a"];

    sqrt2 -> periodic [label="Tail" color="#16a34a"];
    periodic -> periodic [label="Tail = Self" color="#16a34a" fontcolor="#16a34a"];
  }
}
