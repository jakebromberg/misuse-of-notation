flowchart TB
    subgraph Product ["Product proof: a * (b + c)"]
        PS["ProductSeed‹3*2›\nL=3 R=2 T=6"]
        T1["TimesTick\nL=3 R=2 T=7"]
        T2["TimesTick\nL=3 R=2 T=8"]
        T3["TimesTick\nL=3 R=2 T=9"]
        G["TimesGroup\nL=3 R=3 T=9"]
        PS --> T1 --> T2 --> T3 --> G
    end

    subgraph Sum ["DistrSum witness: a*b + a*c"]
        D0["PlusZero‹6›\n6 + 0 = 6"]
        D1["PlusSucc\n6 + 1 = 7"]
        D2["PlusSucc\n6 + 2 = 8"]
        D3["PlusSucc\n6 + 3 = 9"]
        D0 --> D1 --> D2 --> D3
    end

    PS -. "starts at PlusZero" .-> D0
    T1 -. "PlusSucc" .-> D1
    T2 -. "PlusSucc" .-> D2
    T3 -. "PlusSucc" .-> D3
    G -. "pass through" .-> D3

    style PS fill:#dbeafe,stroke:#3b82f6
    style T1 fill:#dbeafe,stroke:#3b82f6
    style T2 fill:#dbeafe,stroke:#3b82f6
    style T3 fill:#dbeafe,stroke:#3b82f6
    style G fill:#dbeafe,stroke:#3b82f6
    style D0 fill:#fed7aa,stroke:#f97316
    style D1 fill:#fed7aa,stroke:#f97316
    style D2 fill:#fed7aa,stroke:#f97316
    style D3 fill:#fed7aa,stroke:#f97316
