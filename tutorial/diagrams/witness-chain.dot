// Witness chain for 2 + 3 = 5: PlusZero<N2> -> PlusSucc -> PlusSucc -> PlusSucc
digraph witness_chain {
  rankdir=LR;
  bgcolor="transparent";
  node [
    fontname="Menlo"
    fontsize=11
    shape=record
    style="rounded,filled"
    fillcolor="#f5f5f4"
    color="#d6d3d1"
    penwidth=1.5
  ];
  edge [
    fontname="Menlo"
    fontsize=10
    color="#9333ea"
    penwidth=1.5
    arrowsize=0.8
  ];

  step0 [label="{PlusZero\<N2\>|L=2  R=0  T=2}" fillcolor="#f3e8ff"];
  step1 [label="{PlusSucc|L=2  R=1  T=3}"];
  step2 [label="{PlusSucc|L=2  R=2  T=4}"];
  step3 [label="{PlusSucc|L=2  R=3  T=5}" fillcolor="#dcfce7"];

  step0 -> step1 [label="wrap"];
  step1 -> step2 [label="wrap"];
  step2 -> step3 [label="wrap"];
}
