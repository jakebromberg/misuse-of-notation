// Three-layer architecture: protocols, macros, type checker
digraph macro_architecture {
  bgcolor="transparent";
  rankdir=TB;
  node [
    fontname="Helvetica Neue"
    fontsize=12
    shape=box
    style="rounded,filled"
    penwidth=1.5
  ];
  edge [
    fontname="Helvetica Neue"
    fontsize=10
    penwidth=1.5
    arrowsize=0.8
  ];

  subgraph cluster_protocols {
    label="Protocol Definitions";
    fontname="Helvetica Neue";
    fontsize=11;
    style="rounded,dashed";
    color="#d6d3d1";
    bgcolor="#fafaf9";
    protocols [
      label="NaturalSum\nNaturalProduct\nNaturalLessThan"
      fillcolor="#dcfce7"
      color="#86efac"
    ];
  }

  subgraph cluster_macro {
    label="Macro Expansion (Proof Search)";
    fontname="Helvetica Neue";
    fontsize=11;
    style="rounded,dashed";
    color="#d6d3d1";
    bgcolor="#fafaf9";
    macro [
      label="@PiConvergenceProof\n@FibonacciProof\n@GoldenRatioProof\n..."
      fillcolor="#f3e8ff"
      color="#c084fc"
    ];
  }

  subgraph cluster_checker {
    label="Type Checker (Proof Verifier)";
    fontname="Helvetica Neue";
    fontsize=11;
    style="rounded,dashed";
    color="#d6d3d1";
    bgcolor="#fafaf9";
    checker [
      label="Structural constraint\nverification"
      fillcolor="#fef3c7"
      color="#fbbf24"
    ];
  }

  protocols -> macro [label="defines witness types" color="#57534e"];
  macro -> checker [label="emits witness chains" color="#9333ea"];
  checker -> protocols [label="verifies conformance" color="#57534e" style=dashed constraint=false];
}
