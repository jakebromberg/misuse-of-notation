// ProofSeed induction pattern
digraph seed_wrapping {
  bgcolor="transparent";
  rankdir=LR;
  node [
    fontname="Menlo"
    fontsize=11
    shape=box
    style="rounded,filled"
    fillcolor="#f5f5f4"
    color="#d6d3d1"
    penwidth=1.5
  ];
  edge [
    fontname="Menlo"
    fontsize=10
    penwidth=1.5
    arrowsize=0.8
  ];

  proof [label="P: NaturalSum\n(a + b = d)" fillcolor="#f3e8ff" color="#c084fc"];
  seed [label="ProofSeed<P>\n(wraps P)" fillcolor="#fef3c7" color="#fbbf24"];
  add1 [label="AddOne<...>\n(c = 1)" fillcolor="#dcfce7" color="#86efac"];
  add2 [label="AddOne<...>\n(c = 2)" fillcolor="#dcfce7" color="#86efac"];
  add3 [label="AddOne<...>\n(c = 3)" fillcolor="#dcfce7" color="#86efac"];

  proof -> seed [label="wrap" color="#9333ea"];
  seed -> add1 [label="AddOne" color="#16a34a"];
  add1 -> add2 [label="AddOne" color="#16a34a"];
  add2 -> add3 [label="AddOne" color="#16a34a"];

  // Result labels
  seed_result [label="AssocProof = P" shape=plaintext fontsize=10 fontcolor="#9333ea"];
  add1_result [label="= PlusSucc<P>" shape=plaintext fontsize=10 fontcolor="#9333ea"];
  add2_result [label="= PlusSucc\u00b2<P>" shape=plaintext fontsize=10 fontcolor="#9333ea"];
  add3_result [label="= PlusSucc\u00b3<P>" shape=plaintext fontsize=10 fontcolor="#9333ea"];

  seed -> seed_result [style=dashed color="#9333ea" arrowhead=none];
  add1 -> add1_result [style=dashed color="#9333ea" arrowhead=none];
  add2 -> add2_result [style=dashed color="#9333ea" arrowhead=none];
  add3 -> add3_result [style=dashed color="#9333ea" arrowhead=none];
}
