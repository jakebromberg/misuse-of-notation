direction: right

PS: "ProductSeed\<3*2\>\nT=6" { style.fill: "#cce5ff" }
T1: "TimesTick\nT=7" { style.fill: "#cce5ff" }
T2: "TimesTick\nT=8" { style.fill: "#cce5ff" }
T3: "TimesTick\nT=9" { style.fill: "#cce5ff" }
G: "TimesGroup\nT=9" { style.fill: "#cce5ff" }

PS -> T1 -> T2 -> T3 -> G

D0: "PlusZero\<6\>\n6+0=6" { style.fill: "#fff3cd" }
D1: "PlusSucc\n6+1=7" { style.fill: "#fff3cd" }
D2: "PlusSucc\n6+2=8" { style.fill: "#fff3cd" }
D3: "PlusSucc\n6+3=9" { style.fill: "#fff3cd" }

D0 -> D1 -> D2 -> D3

PS -> D0: seed {
  style.stroke-dash: 5
}
T1 -> D1: tick {
  style.stroke-dash: 5
}
T2 -> D2: tick {
  style.stroke-dash: 5
}
T3 -> D3: tick {
  style.stroke-dash: 5
}
G -> D3: pass {
  style.stroke-dash: 5
}
